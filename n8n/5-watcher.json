          "name": "MS Graph"
        }
      },
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "jsCode": "function vttToText(v){\n  if(!v) return '';\n  return String(v).split(/\\r?\\n/)\n    .filter(l => l && !/^WEBVTT/i.test(l) && !/^\\d+$/.test(l) && !/-->/.test(l))\n    .join(' ')\n    .replace(/<[^>]+>/g,'')        // strip <v Name> speaker tags etc.\n    .replace(/\\s+/g,' ')\n    .trim();\n}\nconst e = s => String(s==null?'':s).replace(/'/g,\"''\");\nconst tid     = ($('Each transcript').item.json.id) || '';\nconst subject = ($('Get meeting subject').item.json.subject) || '';\nconst text    = vttToText($('Get transcript content').item.json.data || $('Get transcript content').item.json.body || '');\n// Account is matched in SQL against known accounts contained in the subject; falls\n// back to 'UNKNOWN' so we never invent junk accounts. Empty transcripts are skipped.\nconst sql =\n  \"INSERT INTO inbox (source, dedup_key, payload, status) \" +\n  \"SELECT 'teams', '\" + e(tid) + \"', jsonb_build_object(\" +\n    \"'account', COALESCE((SELECT name FROM accounts WHERE '\" + e(subject) + \"' ILIKE '%'||name||'%' ORDER BY length(name) DESC LIMIT 1), 'UNKNOWN'),\" +\n    \"'title', '\" + e(subject) + \"',\" +\n    \"'dedup_key', '\" + e(tid) + \"',\" +\n    \"'transcript', '\" + e(text) + \"'\" +\n  \"), 'pending' \" +\n  \"WHERE '\" + e(text) + \"' <> '' \" +\n  \"ON CONFLICT (dedup_key) DO NOTHING RETURNING id;\";\nreturn [{ json: { sql, transcript_id: tid, subject, chars: text.length } }];"
      },
      "id": "w_build",
      "name": "Build inbox insert",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1420,
        300
      ]
    },
