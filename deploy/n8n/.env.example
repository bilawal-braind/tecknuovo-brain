# ── n8n on Azure Container Apps — configuration ──
# Set these as environment variables (secrets for anything sensitive) on the
# Container App. These are what make n8n keep its data across restarts.

# --- 1. n8n's OWN database (this is the important one) ---------------------
# n8n stores its workflows, credentials and run history in a database. In a
# container it MUST be an external database, or a restart wipes everything.
# Use your EXISTING Azure Postgres SERVER, but a SEPARATE database named "n8n"
# so n8n's internal tables never mix with the Second Brain memory tables.
DB_TYPE=postgresdb
DB_POSTGRESDB_HOST=<your-server>.postgres.database.azure.com
DB_POSTGRESDB_PORT=5432
DB_POSTGRESDB_DATABASE=n8n
DB_POSTGRESDB_USER=<n8n db user>
DB_POSTGRESDB_PASSWORD=<secret>
DB_POSTGRESDB_SCHEMA=public
# Azure Postgres requires SSL:
DB_POSTGRESDB_SSL_ENABLED=true
DB_POSTGRESDB_SSL_REJECT_UNAUTHORIZED=false

# --- 2. Encryption key (MUST be fixed) -------------------------------------
# n8n encrypts stored credentials with this key. If it changes, every saved
# credential becomes unreadable. Generate ONE long random string, store it as a
# secret, and never change it.
N8N_ENCRYPTION_KEY=<a long random string — store as a secret>

# --- 3. Public URL (the Container Apps address) ----------------------------
# So the editor, webhooks and any OAuth callbacks resolve to the real address.
N8N_HOST=<your-app>.<region>.azurecontainerapps.io
N8N_PROTOCOL=https
N8N_PORT=5678
WEBHOOK_URL=https://<your-app>.<region>.azurecontainerapps.io/
N8N_EDITOR_BASE_URL=https://<your-app>.<region>.azurecontainerapps.io/

# --- Timezone (so the 15-min Watcher / crons fire at the right time) -------
GENERIC_TIMEZONE=Europe/London
TZ=Europe/London
