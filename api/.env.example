# Postgres (the private Azure DB — API runs on the VM so it can reach it)
PGHOST=your-server.postgres.database.azure.com
PGPORT=5432
PGDATABASE=postgres
PGUSER=tn_api_read
PGPASSWORD=
# SSL is required by Azure; the pool sets it automatically.

# API
PORT=4000

# Auth: "token" for now (dev), "entra" once the Entra app registration is ready.
AUTH_MODE=token
API_TOKEN=replace-with-a-long-random-string

# Entra (needed when AUTH_MODE=entra). The API validates the user's Microsoft sign-in
# token against this tenant, confirms it's a TN account, and scopes data per user.
ENTRA_TENANT_ID=5de2609a-7085-46d6-a0f5-91c1bdd726b9
ENTRA_CLIENT_ID=fca468fa-3376-4feb-9801-2fcbfc325bb8
# Optional: override the allowed email domain (defaults to tecknuovo.com)
ALLOWED_EMAIL_DOMAIN=tecknuovo.com

# CORS — comma-separated allowed dashboard origins
CORS_ORIGINS=http://localhost:5173
