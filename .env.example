# Data source: 'mock' (default, the bundled demo) or 'live' (real Postgres via the Read API).
VITE_DATA_SOURCE=mock

# Read API base URL.
#   - SSH-tunnel-to-DB + API on your laptop:  http://localhost:4000
#   - API on the VM, port tunnelled to you:    https://<your-tunnel-host>
VITE_API_URL=http://localhost:4000

# Dev bearer token — must equal API_TOKEN on the Read API (AUTH_MODE=token).
# Left blank for mock mode. Swapped for Entra SSO at go-live.
VITE_API_TOKEN=
