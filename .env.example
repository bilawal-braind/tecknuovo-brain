# Data source: 'mock' (default, the bundled demo) or 'live' (real Postgres via the Read API).
VITE_DATA_SOURCE=mock

# Read API base URL.
#   - SSH-tunnel-to-DB + API on your laptop:  http://localhost:4000
#   - API on the VM, port tunnelled to you:    https://<your-tunnel-host>
VITE_API_URL=http://localhost:4000

# Dev bearer token — must equal API_TOKEN on the Read API (AUTH_MODE=token).
# Left blank for mock mode. Swapped for Entra SSO at go-live.
VITE_API_TOKEN=

# --- Microsoft Entra SSO (only set these where you want login — NOT the public demo build) ---
# Turning this on sends users to Microsoft to sign in with their TN account.
# Client ID + Tenant ID are public identifiers (not secrets). Redirect must EXACTLY
# match a "Single-page application" redirect URI registered on the app.
# VITE_AUTH=entra
# VITE_ENTRA_TENANT_ID=5de2609a-7085-46d6-a0f5-91c1bdd726b9
# VITE_ENTRA_CLIENT_ID=fca468fa-3376-4feb-9801-2fcbfc325bb8
# VITE_ENTRA_REDIRECT=http://localhost:3030

# £ figures (SOW / burn / headroom) are hidden by default until a trusted source
# (Synergist) lands. Set to 1 to show them again.
VITE_SHOW_SOW=
